APP_NAME=AI Document Analysis API
APP_ENV=development
HOST=0.0.0.0
PORT=8000
API_KEY=sk_track2_987654321
MAX_FILE_SIZE_MB=20
ENABLE_CELERY=false
REDIS_URL=redis://localhost:6379/0
TESSERACT_CMD=/usr/bin/tesseract
SPACY_MODEL=en_core_web_sm

# Google Cloud Vision Configuration (Optional - for better OCR accuracy)
# Set to true to enable Google Cloud Vision API instead of Tesseract
USE_GOOGLE_VISION=false

# Path to Google Cloud credentials JSON file
# Download from Google Cloud Console → Service Accounts
GOOGLE_CREDENTIALS_PATH=

# Google Cloud Project ID
GOOGLE_VISION_PROJECT_ID=